<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="800.0" prefHeight="600.0">

   <top>
      <HBox spacing="10.0" BorderPane.alignment="CENTER_LEFT" prefHeight="100.0">
         <padding>
            <Insets top="10.0" left="10.0" />
         </padding>
         <children>
            <VBox spacing="5.0">
               <TextField fx:id="input"
                          promptText="Search location"
                          prefWidth="200.0" />

               <TextField fx:id="input2"
                          promptText="Enter destination"
                          prefWidth="200.0"
                          visible="false"
                          managed="false" />

               <ComboBox fx:id="routeMode"
                         promptText="Choose travel mode"
                         prefWidth="200.0"
                         visible="false"
                         managed="false" />
            </VBox>

            <VBox spacing="5.0">
               <Button fx:id="searchButton"
                       text="🔍"
                       prefWidth="40.0" />

               <Button fx:id="toggleDirectionButton"
                       text="☰"
                       prefWidth="40.0" />
            </VBox>

            <Label fx:id="scaleLabel" text="Scale:" />
         </children>
      </HBox>
   </top>

   <center>
      <Canvas fx:id="canvas"
              width="640.0"
              height="480.0"
              BorderPane.alignment="CENTER" />
   </center>
</BorderPane>